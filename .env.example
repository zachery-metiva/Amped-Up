# Amped Up - environment variables
# Copy to .env and fill in your values. Never commit .env.

# Neon Postgres
# Use the pooled connection string from Neon. Keep sslmode=require.
# The app accepts postgresql://, postgres://, or postgresql+psycopg://.
DATABASE_URL=postgresql://user:password@ep-your-neon-host-pooler.region.aws.neon.tech/dbname?sslmode=require

# Comma-separated frontend origins allowed to call the API in production.
# Example: https://amped-up.online,https://www.amped-up.online,https://your-user.github.io
FRONTEND_ORIGINS=https://amped-up.online,https://www.amped-up.online

# Vite frontend build variable. In GitHub Actions, set this as a repository secret.
VITE_API_BASE_URL=https://your-render-service.onrender.com

# watsonx.ai (IBM Cloud)
# API key from https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your-ibm-cloud-api-key-here

# Project ID from watsonx.ai project > Manage > General
WATSONX_PROJECT_ID=ca84b127-745f-4d8f-a8be-706a82a6f110

# Region URL - default is US South (Dallas)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
