  "weather_conditions": {
    "description": "v0.7 added 60 weather and seasonal variant scenes. Weather scenes carry a weather_condition field in their annotation_metadata. Severity uses existing OSHA categories plus multi_defect for compositions. Framing field distinguishes compliant_with_weather (banner stays green), weather_induced_violation (existing severity applies), damage_from_weather (storm/ice damage as defect), and weather_plus_multi_defect (compound).",
    "supported": {
      "ice_loading": "Glaze ice on conductors, icicles, ice-induced sag, dead-end stress, galloping. 12 standalone scenes plus compositions.",
      "snow_accumulation": "Snow on crossarms and ground, snow-loaded service drops, snow-laden tree limbs, snow-saturated soil. 12 standalone scenes plus compositions.",
      "post_storm": "Broken hardware, downed conductors, wind-blown debris, displaced equipment, lightning damage. 12 standalone scenes plus compositions.",
      "summer_thermal": "Conductor thermal sag at max operating temperature causing clearance violations over roads, buildings, vehicles, water, rail. 12 standalone scenes plus compositions."
    },
    "framings": {
      "compliant_with_weather": "Banner green; weather present but design loading respected.",
      "weather_induced_violation": "Banner uses existing severity (serious, other, de_minimis); weather caused the non-compliant condition.",
      "damage_from_weather": "Banner imminent or serious; weather caused damage to hardware/structure (broken arm, downed line, pole lean).",
      "weather_plus_multi_defect": "Banner purple multi_defect; weather compounds with existing field defects."
    }
  },
  "vegetation_clearance_michigan": {
